// Zellij keybinding configuration for "new tab next to current" plugin
//
// Add this snippet to your ~/.config/zellij/config.kdl
//
// Option 1: KDL keybinding (no CWD inheritance — new tab gets session default CWD)
// This works from any context, including non-terminal panes.
keybinds {
    shared_except "locked" {
        bind "Alt n" {
            MessagePlugin "file:~/.config/zellij/plugins/zellij-new-tab-next-to-current.wasm" {
                name "new-tab-right"
            }
        }
    }
}

// Option 2: Shell function (with CWD inheritance)
// Add this to your ~/.bashrc or ~/.zshrc:
//
//   new-tab-right() {
//       zellij pipe \
//           --plugin 'file:~/.config/zellij/plugins/zellij-new-tab-next-to-current.wasm' \
//           --name 'new-tab-right' \
//           -- "$PWD"
//   }
//
// Then type `new-tab-right` in your shell, or bind it to a key in your terminal.
//
// NOTE: The KDL keybinding (Option 1) does NOT support shell variable expansion,
// so $PWD cannot be passed as the payload. If you need the new tab to inherit
// the current pane's working directory, use the shell function (Option 2).
